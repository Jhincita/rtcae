generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// nombre, nro, correo, estado(string)

model Client {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String
  problemStatus String // Victim of Bank Fraud, Real Estate, etc.
  urgent      Boolean  @default(false)
  createdAt   DateTime @default(now())
}
